    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lit": "^3.3.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^11.0.0"
  },
  "peerDependencies": {
    "lit": "^3.3.2"
  }
