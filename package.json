{
  "name": "headless-primitives-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "pnpm --filter @headless-primitives/docs run docs:dev",
    "dev": "pnpm --filter @headless-primitives/playground run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "pnpm -C packages/vanilla/utils run build && pnpm -r run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "release:dry": "pnpm -r publish --access public --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,js,mts,mjs}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.5.0"
}
